{"file":"oem-odm-B_IOYn9B.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AA+LA,YAAQ;AAAA,MACN,OAAO;AAAA,MACP,MAAM;AAAA,QACJ,EAAE,MAAM,eAAe,SAAS,iGAAgG;AAAA,MACpI;AAAA,IACA,CAAC;;;mBAnMMA,eAAAC,WAAA,EAAA,OAAM,0CAAyC,GAAA,MAAA,CAAA,sjDA4CrCC,cAAA,OAAA,UAAkB,giBAiBlBA,cAAA,OAAA,UAA2B,6iBAiB3BA,cAAA,OAAA,UAAkB,6gBAiBlBA,cAAA,OAAA,UAAmB,+hBAiBnBA,cAAA,OAAA,UAAmB,iiBAiBnBA,cAAA,OAAA,UAAqB,mjBAiBrBA,cAAA,OAAA,UAAsB,whBAiBtBA,cAAA,OAAA,UAAiB;;QAmBlB,IAAG;AAAA,QAAW,OAAM;AAAA;yBAA9B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;cADTC,YAAoC,KAAA,EAAjC,OAAM,uBAAsB,CAAA;AAAA,8BAAK,qBACtC;AAAA;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderAttr","_push","_parent","_createVNode"],"sources":["../../../../pages/oem-odm.vue"],"sourcesContent":["<template>\n  <div class=\"container page-section page-top-padding\">\n    <!-- Header Hero Banner -->\n    <div class=\"glass-card oem-hero animate-fade-in-up\">\n      <span class=\"hero-badge\"><i class=\"fa-solid fa-industry\"></i> Private Label Manufacturing</span>\n      <h1>OEM・ODM製品の委託製造</h1>\n      <p class=\"hero-desc\">\n        当社が最も得意とする自社ブランド（プライベートブランド）開発支援。中国の有力提携工場ネットワークを活用し、企画・デザイン提案から、サンプル作成、現地での品質管理、量産、日本への輸入まで、経験豊富な日本人スタッフが一貫して徹底サポートします。\n      </p>\n    </div>\n\n    <!-- Intro Strengths Row -->\n    <div class=\"intro-strengths-row\">\n      <div class=\"strength-card-mini glass-card\">\n        <i class=\"fa-solid fa-people-carry-box\"></i>\n        <h4>現地常駐スタッフによる徹底監修</h4>\n        <p>中国の現地事務所に日本人スタッフが常駐。工場のライン選定や量産品の検品指示を現地で直接チェックするため、高品質な製品をお届けします。</p>\n      </div>\n\n      <div class=\"strength-card-mini glass-card\">\n        <i class=\"fa-solid fa-palette\"></i>\n        <h4>デザイン・ロゴ提案にも対応</h4>\n        <p>お客様の構想をもとに、ロゴマークやパッケージデザインなどを弊社よりご提案させていただくことも可能です。</p>\n      </div>\n\n      <div class=\"strength-card-mini glass-card\">\n        <i class=\"fa-solid fa-shield-halved\"></i>\n        <h4>納得のいくサンプルチェック</h4>\n        <p>量産前に必ずモックアップ（試作サンプル）を作成。ご納得いただけるまで何度でも修正対応を行います。</p>\n      </div>\n    </div>\n\n    <!-- Timeline Title -->\n    <div class=\"timeline-header-block\">\n      <h2 class=\"section-title\">製造開始までの流れ</h2>\n      <p class=\"section-subtitle\">お問い合わせから最終納品まで、8つのステップでスムーズにプロジェクトを進行します。</p>\n    </div>\n\n    <!-- Stepper Timeline Layout -->\n    <div class=\"oem-timeline\">\n      \n      <!-- Step 1 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/tel.png\" alt=\"お問い合わせ\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">01</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>お問い合わせ</h3>\n          <p>\n            まずは当サイトのお問い合わせフォーム、またはお電話（072-479-6355）にてお気軽にご連絡ください。<br>\n            ご検討中の商品イメージ、希望ロット、納期などがお決まりでしたらお伝えください。24時間以内（休業日除く）に担当者よりご返信いたします。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 2 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/conversation.png\" alt=\"ご相談・打合せ\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">02</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>ご相談・お打合せ</h3>\n          <p>\n            ご希望の製品仕様、機能、カラーバリエーション、パッケージ等についてヒアリングを行います。<br>\n            具体的な商品イメージが未確定の場合でも、売れ筋商品のデータ分析や、ノベルティ製品の企画などを弊社よりご提案させていただくことも可能です。サンプルを交えてのご相談も承ります。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 3 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/cal.png\" alt=\"お見積り\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">03</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>お見積り</h3>\n          <p>\n            お打合せの内容に基づき、工場の選定、生産コスト、輸送ルートを確認のうえ、正式なお見積書兼発注書を発行いたします。<br>\n            製品単価だけでなく、初期費用（金型代、版代等）や輸入にかかる概算費用もわかりやすく明記いたします。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 4 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/sign.png\" alt=\"ご発注・契約\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">04</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>ご発注・ご契約</h3>\n          <p>\n            お見積り内容および諸条件をご確認いただき、ご納得いただけましたら正式なご契約を締結いたします。<br>\n            お支払い方法は原則前金（銀行振込）となりますが、継続的なお取引のお客様や大口案件につきましては、掛け払い・後払いなども個別にご相談に応じます。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 5 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/data.png\" alt=\"データ入稿\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">05</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>デザインデータ入稿</h3>\n          <p>\n            製品に印字するロゴ、キャラクター、説明書、パッケージ用のAIデザインデータ等をご入稿いただきます。<br>\n            お客様でのデータ作成が難しい場合、弊社の提携デザイナーチームによるロゴマークの提案・作成代行も可能です（詳細はお打合せ時にお伝えください）。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 6 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/sample.png\" alt=\"サンプル作成\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">06</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>サンプル作成 ＆ 仕様確認</h3>\n          <p>\n            入稿データを元に製品のイメージ図（レンダリング）を作成・合意のうえ、試作サンプルを作成します。<br>\n            完成した現物サンプルをお客様へ送付しますので、形状、色合い、素材感、ロゴの仕上がりを手にとってご確認ください。必要に応じて、ご満足いただけるまで修正サンプルを作成します。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 7 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/product.png\" alt=\"量産・検品\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">07</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>量産開始 ＆ 現地検品</h3>\n          <p>\n            最終サンプルをご確認いただき、量産のGoサインをいただいた後、本生産を開始します。<br>\n            出荷前に現地倉庫にて厳密な製品チェック（二重検品）を実施します。品質管理に厳しい日本人スタッフの目を通して不良品を徹底的に排除します。\n          </p>\n        </div>\n      </div>\n\n      <!-- Step 8 -->\n      <div class=\"oem-step-row animate-fade-in-up\">\n        <div class=\"oem-step-icon-col\">\n          <div class=\"icon-circle\">\n            <img src=\"/img/pl.png\" alt=\"納品\" class=\"oem-icon-img\">\n          </div>\n          <span class=\"step-num-badge\">08</span>\n        </div>\n        <div class=\"oem-step-content-col glass-card\">\n          <h3>納品・国際輸送</h3>\n          <p>\n            検品完了後、ご指定の配送方法（お急ぎの場合は航空便、コスト重視の場合は快速船便）で日本のご指定の倉庫または店舗・FBA倉庫へ直接納品いたします。<br>\n            通関手続きや各種法令申請も弊社が手配をサポートしますので、貿易が初めての方でも安心してお待ちいただけます。\n          </p>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Bottom CTA Block -->\n    <div class=\"oem-cta glass-card text-center\">\n      <h3>自社オリジナル商品の開発を始めましょう！</h3>\n      <p>競合他社との差別化、自社ブランドでの高利益率化には、OEM・ODMが不可欠です。まずはお気軽にご相談ください。</p>\n      <NuxtLink to=\"/contact\" class=\"btn-primary\">\n        <i class=\"fa-solid fa-envelope\"></i> OEM・ODM製造について相談する\n      </NuxtLink>\n    </div>\n  </div>\n</template>\n\n<script setup>\nuseHead({\n  title: 'OEM・ODM委託製造 - asuka',\n  meta: [\n    { name: 'description', content: 'asukaのOEM・ODMプライベートブランド製品委託製造。中国工場との交渉、見積り、データ入稿、サンプル試作、量産検品、国際輸送からFBA倉庫納品まで日本人スタッフが直接サポートします。' }\n  ]\n})\n</script>\n\n<style scoped>\n.page-top-padding {\n  padding-top: 100px;\n}\n\n.oem-hero {\n  padding: 4rem 3rem;\n  background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(30, 41, 59, 0.9) 100%);\n  color: #ffffff;\n  margin-bottom: 4rem;\n}\n\n.oem-hero h1 {\n  font-size: 2.5rem;\n  font-weight: 800;\n  color: #ffffff;\n  margin-bottom: 1.5rem;\n}\n\n.oem-hero .hero-desc {\n  font-size: 1.1rem;\n  line-height: 1.8;\n  color: #cbd5e1;\n  max-width: 850px;\n}\n\n.hero-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-size: 0.85rem;\n  font-weight: 700;\n  color: #818cf8;\n  background-color: rgba(99, 102, 241, 0.15);\n  padding: 0.5rem 1.25rem;\n  border-radius: var(--border-pill);\n  border: 1px solid rgba(129, 140, 248, 0.3);\n  margin-bottom: 1.25rem;\n}\n\n/* Intro Strengths Row */\n.intro-strengths-row {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 1.5rem;\n  margin-bottom: 5rem;\n}\n\n.strength-card-mini {\n  padding: 2rem 1.5rem;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  gap: 1rem;\n  height: 100%;\n}\n\n.strength-card-mini i {\n  font-size: 2rem;\n  color: var(--color-primary);\n}\n\n.strength-card-mini h4 {\n  font-size: 1.1rem;\n  font-weight: 700;\n}\n\n.strength-card-mini p {\n  font-size: 0.85rem;\n  color: var(--text-muted);\n  line-height: 1.6;\n}\n\n/* Stepper Timeline styles */\n.oem-timeline {\n  max-width: 900px;\n  margin: 0 auto 5rem;\n  position: relative;\n}\n\n/* Timeline Vertical Line */\n.oem-timeline::before {\n  content: '';\n  position: absolute;\n  top: 40px;\n  bottom: 40px;\n  left: 60px;\n  width: 4px;\n  background: var(--bg-secondary);\n  z-index: 1;\n}\n\n.oem-step-row {\n  display: flex;\n  gap: 2.5rem;\n  margin-bottom: 3rem;\n  position: relative;\n  z-index: 2;\n}\n\n.oem-step-icon-col {\n  width: 120px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  flex-shrink: 0;\n}\n\n.icon-circle {\n  width: 80px;\n  height: 80px;\n  background-color: #ffffff;\n  border: 4px solid var(--bg-secondary);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: var(--shadow-md);\n  transition: all 0.3s ease;\n}\n\n.oem-step-row:hover .icon-circle {\n  border-color: var(--color-primary-light);\n  transform: scale(1.05);\n}\n\n.oem-icon-img {\n  width: 45px;\n  height: 45px;\n  object-fit: contain;\n}\n\n.step-num-badge {\n  display: inline-block;\n  font-size: 0.8rem;\n  font-weight: 800;\n  color: var(--color-primary);\n  background-color: rgba(99, 102, 241, 0.08);\n  padding: 0.15rem 0.5rem;\n  border-radius: var(--border-pill);\n  margin-top: 0.75rem;\n}\n\n.oem-step-content-col {\n  flex: 1;\n  padding: 2.5rem;\n}\n\n.oem-step-content-col h3 {\n  font-size: 1.3rem;\n  font-weight: 800;\n  margin-bottom: 0.75rem;\n  color: var(--text-main);\n}\n\n.oem-step-content-col p {\n  font-size: 0.95rem;\n  color: var(--text-muted);\n  line-height: 1.75;\n}\n\n/* CTA Bottom */\n.oem-cta {\n  padding: 3.5rem;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.25rem;\n}\n\n.oem-cta h3 {\n  font-size: 1.4rem;\n  font-weight: 700;\n}\n\n.oem-cta p {\n  color: var(--text-muted);\n  max-width: 600px;\n  margin-bottom: 1rem;\n}\n\n@media (max-width: 768px) {\n  .oem-timeline::before {\n    display: none;\n  }\n  .oem-step-row {\n    flex-direction: column;\n    gap: 1.5rem;\n  }\n  .oem-step-icon-col {\n    width: 100%;\n    flex-direction: row;\n    justify-content: flex-start;\n    gap: 1.5rem;\n  }\n  .icon-circle {\n    width: 60px;\n    height: 60px;\n  }\n  .oem-icon-img {\n    width: 32px;\n    height: 32px;\n  }\n  .step-num-badge {\n    margin-top: 0;\n  }\n  .intro-strengths-row {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n"],"version":3}