font-size: 1.15rem;\n  color: var(--color-primary);\n  text-align: center;\n  border-top: 2px solid var(--text-main);\n}\n\n.savings-alert {\n  margin-top: 1rem;\n  background: rgba(16, 185, 129, 0.1);\n  color: #065f46;\n  padding: 0.85rem 1.25rem;\n  border-radius: var(--border-radius-sm);\n  font-size: 0.95rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-weight: 500;\n}\n\n.savings-alert i {\n  color: #10b981;\n}\n\n/* Strengths Section */\n.strengths-container {\n  display: grid;\n  grid-template-columns: 0.9fr 1.1fr;\n  gap: 4rem;\n  align-items: center;\n}\n\n.strengths-graphics {\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n}\n\n.strength-gif {\n  width: 100%;\n  border-radius: var(--border-radius-md);\n  box-shadow: var(--shadow-lg);\n  border: 1px solid rgba(0,0,0,0.05);\n}\n\n.gifs-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 1.5rem;\n}\n\n.strength-gif-sm {\n  width: 100%;\n  border-radius: var(--border-radius-md);\n  box-shadow: var(--shadow-md);\n  border: 1px solid rgba(0,0,0,0.05);\n}\n\n.strengths-list {\n  display: flex;\n  flex-direction: column;\n  gap: 1.75rem;\n}\n\n.strength-item-card {\n  background: #ffffff;\n  border-radius: var(--border-radius-md);\n  padding: 1.5rem;\n  display: flex;\n  gap: 1.5rem;\n  box-shadow: var(--shadow-sm);\n  border: 1px solid rgba(0,0,0,0.02);\n  transition: transform 0.2s ease;\n}\n\n.strength-item-card:hover {\n  transform: translateX(4px);\n  box-shadow: var(--shadow-md);\n}\n\n.strength-num {\n  font-size: 1.8rem;\n  font-weight: 800;\n  color: var(--color-primary-light);\n  line-height: 1;\n}\n\n.strength-item-card h4 {\n  font-size: 1.1rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n}\n\n.strength-item-card p {\n  color: var(--text-muted);\n  font-size: 0.9rem;\n  line-height: 1.6;\n}\n\n/* ============================\n   Pricing Plans Section\n   ============================ */\n\n/* Toggle */\n.plan-toggle-wrap {\n  display: flex;\n  justify-content: center;\n  gap: 0.75rem;\n  margin-bottom: 3rem;\n  background: rgba(255,255,255,0.7);\n  padding: 0.5rem;\n  border-radius: var(--border-pill);\n  width: fit-content;\n  margin-left: auto;\n  margin-right: auto;\n  box-shadow: var(--shadow-sm);\n  border: 1px solid rgba(0,0,0,0.06);\n}\n\n.plan-toggle-btn {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.7rem 1.75rem;\n  border: none;\n  border-radius: var(--border-pill);\n  font-size: 0.95rem;\n  font-weight: 600;\n  cursor: pointer;\n  background: transparent;\n  color: var(--text-muted);\n  transition: all 0.25s ease;\n}\n\n.plan-toggle-btn.active {\n  background: var(--grad-royal);\n  color: #ffffff;\n  box-shadow: 0 4px 16px rgba(79, 70, 229, 0.25);\n}\n\n/* Cards Grid */\n.plans-grid {\n  display: grid;\n  grid-template-columns: 1fr 1.15fr 1fr;\n  gap: 1.75rem;\n  align-items: stretch; /* Ensure cards have equal height */\n  margin-bottom: 2rem;\n}\n\n/* Individual Card */\n.plan-card {\n  position: relative;\n  padding: 2.25rem 2rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  border: 1.5px solid rgba(0,0,0,0.06);\n}\n\n.plan-card--active {\n  transform: translateY(-6px);\n  box-shadow: 0 20px 48px rgba(79, 70, 229, 0.15) !important;\n}\n\n/* Gold Card Special */\n.plan-card--gold {\n  background: linear-gradient(145deg, #fff9ee 0%, #ffffff 60%, #fffbf0 100%);\n  border: 2px solid rgba(217, 119, 6, 0.3);\n  transform: translateY(-8px);\n  box-shadow: 0 16px 40px rgba(217, 119, 6, 0.12) !important;\n}\n\n.plan-card--gold.plan-card--active {\n  transform: translateY(-14px);\n  box-shadow: 0 24px 56px rgba(217, 119, 6, 0.22) !important;\n}\n\n/* Custom Card */\n.plan-card--custom {\n  background: linear-gradient(145deg, #f0f4ff 0%, #ffffff 70%);\n  border: 1.5px solid rgba(79, 70, 229, 0.12);\n}\n\n/* Popular Badge */\n.plan-popular-badge {\n  position: absolute;\n  top: -14px;\n  left: 50%;\n  transform: translateX(-50%);\n  background: linear-gradient(90deg, #d97706, #f59e0b);\n  color: #ffffff;\n  font-size: 0.78rem;\n  font-weight: 700;\n  padding: 0.3rem 1.25rem;\n  border-radius: var(--border-pill);\n  white-space: nowrap;\n  box-shadow: 0 4px 12px rgba(217, 119, 6, 0.3);\n  letter-spacing: 0.03em;\n}\n\n/* Card Header */\n.plan-card-header {\n  margin-bottom: 1.75rem;\n}\n\n.plan-label {\n  display: inline-block;\n  font-size: 0.8rem;\n  font-weight: 700;\n  background: rgba(99, 102, 241, 0.1);\n  color: var(--color-primary);\n  padding: 0.25rem 0.85rem;\n  border-radius: var(--border-pill);\n  margin-bottom: 0.75rem;\n  letter-spacing: 0.04em;\n}\n\n.plan-label--gold {\n  background: rgba(217, 119, 6, 0.12);\n  color: #b45309;\n}\n\n.plan-label--custom {\n  background: rgba(30, 41, 59, 0.08);\n  color: #334155;\n}\n\n.plan-price {\n  display: flex;\n  flex-direction: column;\n  gap: 0.2rem;\n}\n\n.plan-price-tag {\n  font-size: 2.25rem;\n  font-weight: 800;\n  color: var(--text-main);\n  line-height: 1.1;\n}\n\n.plan-price-tag small {\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--text-muted);\n}\n\n.plan-price-tag--gold {\n  color: #b45309;\n}\n\n.plan-price-tag--custom {\n  font-size: 1.75rem;\n  color: var(--color-primary);\n}\n\n.plan-price-sub {\n  font-size: 0.78rem;\n  color: var(--text-muted);\n  font-weight: 500;\n}\n\n/* Feature List */\n.plan-features {\n  list-style: none;\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n  margin-bottom: 2rem;\n  flex-grow: 1;\n  padding: 0;\n}\n\n.plan-features li {\n  display: flex;\n  gap: 0.85rem;\n  align-items: flex-start;\n  font-size: 0.88rem;\n  line-height: 1.5;\n  color: var(--text-muted);\n  padding-bottom: 1rem;\n  border-bottom: 1px solid rgba(0,0,0,0.05);\n}\n\n.plan-features li:last-child {\n  border-bottom: none;\n  padding-bottom: 0;\n}\n\n.plan-features li strong {\n  display: block;\n  font-weight: 700;\n  color: var(--text-main);\n  font-size: 0.85rem;\n  margin-bottom: 0.15rem;\n}\n\n.feat-highlight {\n  position: relative;\n}\n\n.feat-icon {\n  width: 34px;\n  height: 34px;\n  min-width: 34px;\n  border-radius: 10px;\n  background: rgba(99, 102, 241, 0.08);\n  color: var(--color-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 0.9rem;\n  margin-top: 0.1rem;\n}\n\n.feat-icon--gold {\n  background: rgba(217, 119, 6, 0.1);\n  color: #d97706;\n}\n\n.feat-icon--custom {\n  background: rgba(79, 70, 229, 0.1);\n  color: var(--color-primary);\n}\n\n.highlight-text {\n  font-weight: 700;\n  color: #b45309;\n}\n\n/* CTA Button in card */\n.plan-cta {\n  display: block;\n  text-align: center;\n  padding: 0.9rem 1.25rem;\n  font-size: 0.95rem;\n  font-weight: 700;\n  border-radius: var(--border-pill);\n  transition: all 0.25s ease;\n  margin-top: auto;\n}\n\n.btn-custom {\n  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);\n  color: #ffffff;\n  border: none;\n  cursor: pointer;\n}\n\n.btn-custom:hover {\n  opacity: 0.88;\n  transform: translateY(-2px);\n  box-shadow: 0 8px 20px rgba(30, 41, 59, 0.25);\n}\n\n/* Common features bar */\n.plans-common-row {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  gap: 0.75rem;\n  margin-bottom: 2.5rem;\n  margin-top: 0.5rem;\n}\n\n.common-badge {\n  display: flex;\n  align-items: center;\n  gap: 0.4rem;\n  background: rgba(16, 185, 129, 0.08);\n  color: #065f46;\n  font-size: 0.82rem;\n  font-weight: 600;\n  padding: 0.45rem 1rem;\n  border-radius: var(--border-pill);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n}\n\n.common-badge i {\n  color: #10b981;\n}\n\n/* Footer Link */\n.plans-footer-link {\n  text-align: center;\n}\n\n@media (max-width: 900px) {\n  .plans-grid {\n    grid-template-columns: 1fr;\n    gap: 2rem;\n  }\n  .plan-card--gold {\n    transform: none;\n  }\n  .plan-card--gold.plan-card--active {\n    transform: translateY(-6px);\n  }\n  .plan-toggle-wrap {\n    flex-direction: column;\n    width: 100%;\n    max-width: 380px;\n  }\n}\n\n/* CTA Section custom styling */\n.cta-card {\n  padding: 4rem 3rem;\n  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(239, 246, 255, 0.9) 100%);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.cta-icon {\n  width: 80px;\n  height: 80px;\n  border-radius: 50%;\n  background: rgba(99, 102, 241, 0.1);\n  color: var(--color-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 2.5rem;\n  margin-bottom: 2rem;\n}\n\n.cta-card h2 {\n  font-size: 2.2rem;\n  font-weight: 800;\n  margin-bottom: 1.5rem;\n}\n\n.cta-card p {\n  font-size: 1.1rem;\n  color: var(--text-muted);\n  line-height: 1.8;\n  max-width: 750px;\n  margin-bottom: 3rem;\n}\n\n.cta-buttons {\n  display: flex;\n  gap: 1.5rem;\n  justify-content: center;\n}\n\n.btn-large {\n  padding: 1.1rem 2.5rem;\n  font-size: 1.1rem;\n}\n\n@media (max-width: 1024px) {\n  .comparison-grid, .strengths-container {\n    grid-template-columns: 1fr;\n    gap: 3rem;\n  }\n}\n\n@media (max-width: 600px) {\n  .cta-buttons {\n    flex-direction: column;\n    gap: 1rem;\n  }\n  .btn-large {\n    width: 100%;\n  }\n  .cta-card h2 {\n    font-size: 1.75rem;\n  }\n}\n</style>\n"],"version":3}